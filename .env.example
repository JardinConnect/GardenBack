JWT_ALGORITHM = "HS256"
# if needed, we can  generate the secret with `openssl rand -hex 32``
JWT_SECRET = 

# FastAPI
APP_ENV=
APP_PORT=

# MQTT
MQTT_BROKER=
MQTT_PORT=
MQTT_KEEPALIVE=

# Définir à "true" pour simuler les interactions MQTT (utile pour le dev frontend ou les tests sans broker).
MOCK_MQTT=false

DATABASE_URL=sqlite:////app/database.db
